# Lenochka — конфигурация окружения
# Скопировать в .env и заполнить реальными значениями

# Telegram
OWNER_ID=YOUR_TELEGRAM_USER_ID
BOT_USERNAME=your_bot_username

# Timezone (смещение в часах от UTC)
OWNER_TZ_OFFSET=8

# Пути (опционально, по умолчанию вычисляются от PROJECT_ROOT)
# DB_PATH=/absolute/path/to/lenochka.db
# LOAD_DIR_BASE=/tmp/lenochka_load
